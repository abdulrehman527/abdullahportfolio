# Environment Variables for Vercel Deployment

# API Configuration
REACT_APP_API_URL=https://your-vercel-project.vercel.app/api

# MongoDB Configuration
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=portfolio_db

# CORS Configuration (comma-separated domains)
CORS_ORIGINS=https://your-vercel-project.vercel.app,https://your-custom-domain.com

# Frontend Environment Variables
# REACT_APP_API_URL (already defined above)
